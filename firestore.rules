rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read, list, create, update, delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);

      // Messages subcollection
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
      }
    }

    // Memories
    match /users/{userId}/memories/{memoryId} {
      allow read, list, write: if isOwner(userId);
    }
  }
}
